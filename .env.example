# @supabase/server environment variables
# Copy this file to `.env` and paste the real values from the Supabase
# dashboard -> Project Settings -> Connect (or API Keys).
#
# .env is gitignored. NEVER commit the secret key.
#
# NOTE: On Supabase Edge Functions these four values are injected
# automatically by the platform — you only need them for local dev
# (`supabase functions serve`) and for any non-Edge runtime.

# Project URL, e.g. https://<ref>.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable key (sb_publishable_...). Safe to expose to the browser.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Secret key (sb_secret_...). SERVER-ONLY. Never expose or commit this.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# JWKS endpoint used to verify user JWTs (auth: 'user').
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
